<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/playerRoot" android:background="#000000" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.media3.ui.PlayerView android:id="@+id/playerView" android:layout_width="match_parent" android:layout_height="match_parent" android:keepScreenOn="true"/>
    <LinearLayout android:id="@+id/playerTopControls" android:orientation="horizontal" android:gravity="end" android:padding="12dp" android:layout_gravity="top|end" android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/timerBtn" android:text="Sleep" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <TextView android:id="@+id/gestureOverlay" android:visibility="gone" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:background="#99000000" android:padding="14dp" android:layout_gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</FrameLayout>
